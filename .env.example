# Copie este arquivo para .env e preencha os valores

# Token do bot do Discord (https://discord.com/developers/applications)
DISCORD_TOKEN=

# ID do servidor (guild) do Discord onde vocês jogam
# (Ative o Modo Desenvolvedor no Discord, clique com o direito no servidor > Copiar ID)
DISCORD_GUILD_ID=

# Chave da API da Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Chave da API do Freesound, para buscar/importar sons pelo painel (opcional)
# Grátis: crie em https://freesound.org/apiv2/apply
FREESOUND_API_KEY=

# Porta do painel web (opcional, padrão 3000)
PORT=3000

# ---- Portal do jogador (login com Discord) — opcional ----
# Sem estas variáveis, o painel do Mestre funciona normalmente; só o portal
# do jogador (/jogador.html) fica indisponível até serem preenchidas.
#
# CLIENT ID e CLIENT SECRET vêm do MESMO app do bot em
# https://discord.com/developers/applications > sua aplicação > OAuth2.
# O Client ID geralmente é igual ao "Application ID" da aba General.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Em Discord Developer Portal > OAuth2 > Redirects, cadastre exatamente:
#   http://localhost:3000/auth/discord/callback
# (troque a porta/domínio se mudar onde o painel roda)

# Seu ID de usuário do Discord (não o do servidor) — quem tiver este ID
# entra no portal como Mestre em vez de jogador. Vários IDs: separe por vírgula.
GM_DISCORD_ID=

# Chave aleatória para assinar o cookie de sessão dos jogadores — troque por
# qualquer texto longo e aleatório antes de expor o painel além do localhost.
SESSION_SECRET=
